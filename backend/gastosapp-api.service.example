[Unit]
Description=GastosApp FastAPI SQLite
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/gastosapp
Environment=GASTOSAPP_DB_PATH=/opt/gastosapp/backend/data/gastosapp.sqlite
Environment=GASTOSAPP_ADMIN_EMAIL=vedu.gutierrez@gmail.com
ExecStart=/opt/gastosapp/backend/.venv/bin/uvicorn backend.app.main:app --host 0.0.0.0 --port 8010
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
